{
	"schemaVersion": 1,
	"id": "potions-belt",
	"version": "${version}",
	"name": "Potion's Belt",
	"description": "A wearable potion belt: a 27-slot container that only accepts potions. Hold right click to drink the first available potion, or press a number key (1-9) while drinking to pick a column.",
	"authors": [
		"Scr0ols"
	],
	"contact": {
		"sources": "https://github.com/scr0ols/Potions-Belt"
	},
	"license": "MIT",
	"icon": "assets/potions-belt/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"scr0ols.potionsbelt.PotionsBelt"
		],
		"client": [
			"scr0ols.potionsbelt.PotionsBeltClient"
		]
	},
	"mixins": [
		"potions-belt.mixins.json",
		{
			"config": "potions-belt.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.4",
		"minecraft": ">=26.1",
		"java": ">=21",
		"fabric-api": "*"
	}
}
